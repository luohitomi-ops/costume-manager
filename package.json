{
  "name": "costume-manager",
  "version": "0.1.0",
  "description": "Self-hostable costume/prop inventory tracker for cosplayers",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "node --test tests/",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/style.css --watch"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.17",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2"
  }
}
