# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — your values never get committed.

# Which database driver to use. Leave unset (or "local") for a plain
# local SQLite file at data/costume-manager.db — this is all you need
# for self-hosting on your own machine.
# Set to "turso" only if you're deploying your own cloud instance (see
# README's "Deploy your own cloud instance" section).
DB_DRIVER=local

# Required only when DB_DRIVER=turso. Create your own free Turso
# database (https://turso.tech) and paste its values here — do not
# reuse anyone else's.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Required only when DB_DRIVER=turso. This is the single shared
# password that gates access to your cloud instance (no accounts, no
# password reset — pick something only you know).
ACCESS_PASSWORD=
